# Velum MCP Server — environment configuration
# Copy to .env and fill in your values.

# ── Velum connection ──────────────────────────────────────────────────────────
# Base URL of your Velum instance (no trailing slash)
VELUM_URL=http://localhost:3000

# API token from Velum → Profile → API Tokens
VELUM_API_TOKEN=your_api_token_here

# Request timeout in seconds (default: 30)
VELUM_TIMEOUT_SECS=30

# ── Transport ─────────────────────────────────────────────────────────────────
# "stdio"  — for Claude Desktop / Claude Code (local binary, default)
# "http"   — for networked access / Docker deployments
MCP_TRANSPORT=stdio

# Port for HTTP transport (ignored when MCP_TRANSPORT=stdio)
MCP_PORT=8500

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: error | warn | info | debug | trace
RUST_LOG=velum_mcp=info
