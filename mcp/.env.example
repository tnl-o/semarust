# ── Required ───────────────────────────────────────────────────────────────────
# URL of your Velum instance
VELUM_URL=http://localhost:8088

# API token — generate at: Velum → User Settings → API Tokens → + New Token
VELUM_API_TOKEN=your-token-here

# ── Optional ───────────────────────────────────────────────────────────────────
# HTTP request timeout in seconds (default: 30)
# VELUM_TIMEOUT=30

# MCP transport: 'stdio' (for Claude Desktop/Code) or 'http' (for remote/Docker)
# MCP_TRANSPORT=stdio

# Bind address when using HTTP transport
# MCP_HOST=0.0.0.0

# Port when using HTTP transport
# MCP_PORT=8500
